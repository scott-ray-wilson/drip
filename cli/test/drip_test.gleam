pub fn add_writes_nothing_when_a_fetch_fails_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_add_atomic")
  write_project(directory)
  write_source_theme(directory, "")
  // `broken.gleam` is in the registry but absent at the source, so the fetch
  // fails mid-batch before any write is reached.
  write_registry(
    directory,
    element("broken", [], [], ["broken.css", "broken.gleam"]),
  )
  write_source_file(directory, "broken.css", ".broken {}\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(_) = cli.run(project, ["init"])
  let index_before = simplifile.read(directory <> "/src/ui/index.css")

  let assert Error(error.FailedToReadSourceFile(_, _)) =
