  // Nothing is written; not even the file that fetched successfully.
  assert simplifile.is_file(directory <> "/src/ui/broken.css") == Ok(False)
  assert simplifile.is_file(directory <> "/src/ui/broken.gleam") == Ok(False)
  assert simplifile.read(directory <> "/src/ui/index.css") == index_before
}

