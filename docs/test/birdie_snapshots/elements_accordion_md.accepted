          ),
        ]),
      ]),
    ]),
  ])
}
```

### Filled

Bordered, filled rows collapsed into a single group. Solid enough to stand as a section of its own.

```gleam
import lustre/attribute
import lustre/element.{type Element}
import lustre/element/html
import ui/accordion
import ui/icon

pub fn view() -> Element(message) {
