// --- Remove Command ----------------------------------------------------------

pub fn remove_deletes_files_and_rewrites_index_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_remove")
  write_project(directory)
  write_source_theme(directory, "/* tokens */\n")
  write_registry(
    directory,
    element("field", ["separator"], [], ["field.gleam", "field.css"])
      <> ","
      <> element("separator", [], [], ["separator.gleam", "separator.css"]),
  )
  write_source_file(directory, "field.gleam", "import ui/separator\n")
  write_source_file(directory, "field.css", ".field {}\n")
  write_source_file(directory, "separator.gleam", "pub const sep = True\n")
  write_source_file(directory, "separator.css", ".separator {}\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(_) = cli.run(project, ["init"])
  let assert Ok(_) = cli.run(project, ["add", "field"])

  let assert Ok(output) = cli.run(project, ["remove", "field"])

  // field's own files are gone...
  assert simplifile.is_file(directory <> "/src/ui/field.gleam") == Ok(False)
  assert simplifile.is_file(directory <> "/src/ui/field.css") == Ok(False)

  // ...but its dependency is left in place.
  assert simplifile.is_file(directory <> "/src/ui/separator.gleam") == Ok(True)
  assert simplifile.is_file(directory <> "/src/ui/separator.css") == Ok(True)

  // The index is re-derived from what's left, dropping field's import.
  assert simplifile.read(directory <> "/src/ui/index.css")
    == Ok(
      "/* Generated by drip; do not edit. Run drip add / drip remove to change it. */\n"
      <> "@import \"./theme.css\";\n"
      <> "@import \"./separator.css\";\n",
    )

  assert output
    == "Removed 1 element from src/ui.\n\n"
    <> "  - deleted  src/ui/field.css\n"
    <> "  - deleted  src/ui/field.gleam\n"
    <> "  ~ modified src/ui/index.css"
}

