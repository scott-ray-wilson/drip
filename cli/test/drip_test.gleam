pub fn init_force_overwrites_existing_files_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init_force")
  write_project(directory)
  write_source_theme(directory, "new\n")
  let assert Ok(Nil) = simplifile.create_directory_all(directory <> "/src/ui")
  let assert Ok(Nil) =
    simplifile.write(to: directory <> "/src/ui/theme.css", contents: "old\n")
  let assert Ok(Nil) =
    simplifile.write(to: directory <> "/src/ui/index.css", contents: "stale\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(output) = cli.run(project, ["init", "--force"])

  // Overwriting pre-existing files is reported as modified, not created.
  assert_change(output, "modified", "src/ui/theme.css")
  assert_change(output, "modified", "src/ui/index.css")

  assert simplifile.read(directory <> "/src/ui/theme.css") == Ok("new\n")
  assert simplifile.read(directory <> "/src/ui/index.css")
    == Ok(
      "/* Generated by drip; do not edit. Run drip add / drip remove to change it. */\n"
      <> "@import \"./theme.css\";\n",
    )
}

pub fn init_force_skips_files_whose_content_is_unchanged_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init_force_noop")
  write_project(directory)
  write_source_theme(directory, "/* tokens */\n")

  // Pre-seed the scaffolded files with exactly what drip would write.
  let assert Ok(Nil) = simplifile.create_directory_all(directory <> "/src/ui")
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/src/ui/theme.css",
      contents: "/* tokens */\n",
    )
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/src/ui/index.css",
      contents: "/* Generated by drip; do not edit. Run drip add / drip remove to change it. */\n"
        <> "@import \"./theme.css\";\n",
    )
  // The entry is already fully wired, so it too is left untouched.
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/src/app.css",
      contents: "@import \"tailwindcss\";\n@import \"./ui/index.css\";\n",
    )

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(output) = cli.run(project, ["init", "--force"])

  // A forced re-init over an already-initialized project changes nothing.
  assert_change(output, "skipped", "src/ui/theme.css")
  assert_change(output, "skipped", "src/ui/index.css")
  assert_change(output, "skipped", "src/app.css")
  assert string.contains(output, "src/ui/theme.css (unchanged)")
  assert string.contains(output, "already initialized")
  assert string.contains(output, "gleam run -m drip -- add")
}

pub fn init_force_re_derives_the_index_from_vendored_elements_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init_force_vendored")
  write_project(directory)
  write_source_theme(directory, "/* tokens */\n")
  write_registry(
    directory,
    element("button", [], [], ["button.gleam", "button.css"]),
  )
  write_source_file(directory, "button.gleam", "pub const fixture = True\n")
  write_source_file(directory, "button.css", ".button {}\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(_) = cli.run(project, ["init"])
  let assert Ok(_) = cli.run(project, ["add", "button"])

  // Forcing a re-init must rebuild the index from the elements on disk, not
  // reset it to theme-only and orphan button's styles.
  let assert Ok(output) = cli.run(project, ["init", "--force"])

  let assert Ok(index) = simplifile.read(directory <> "/src/ui/index.css")
  assert string.contains(index, "@import \"./theme.css\";")
  assert string.contains(index, "@import \"./button.css\";")

  // The index already imported button, so the re-derived body matches.
  assert_change(output, "unchanged", "src/ui/index.css")
}

