  write_source_theme(directory, "")
  write_registry(
    directory,
    element("button", [], [], ["button.gleam", "button.css"]),
  )
  write_source_file(directory, "button.gleam", "pub const fixture = True\n")
  write_source_file(directory, "button.css", ".button {}\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(_) = cli.run(project, ["init"])
  let assert Ok(_) = cli.run(project, ["add", "button"])

  // A local edit to a vendored, consumer-owned file.
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/src/ui/button.gleam",
      contents: "// mine\n",
    )

  // A plain re-add skips the vendored element, leaving the edit untouched.
  let assert Ok(output) = cli.run(project, ["add", "button"])
  assert simplifile.read(directory <> "/src/ui/button.gleam") == Ok("// mine\n")
  assert output
    == "Requested elements are already vendored in src/ui.\n\n"
    <> "  = skipped button (already vendored)"
}

