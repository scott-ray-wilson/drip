// --- Init Command ------------------------------------------------------------

pub fn init_scaffolds_stylesheets_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init")
  write_project(directory)
  write_source_theme(directory, "/* tokens */\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(output) = cli.run(project, ["init"])

  // Theme is fetched from the source verbatim.
  assert simplifile.read(directory <> "/src/ui/theme.css")
    == Ok("/* tokens */\n")

  // Index carries the header and imports the theme.
  assert simplifile.read(directory <> "/src/ui/index.css")
    == Ok(
      "/* Generated by drip; do not edit. Run drip add / drip remove to change it. */\n"
      <> "@import \"./theme.css\";\n",
    )

  // Entry leads with tailwind, then points at the index under the prefix.
  assert simplifile.read(directory <> "/src/app.css")
    == Ok("@import \"tailwindcss\";\n@import \"./ui/index.css\";\n")

  assert string.contains(output, "Initialized drip in src/ui")
  assert_change(output, "created", "src/ui/theme.css")
  assert_change(output, "created", "src/ui/index.css")
  assert_change(output, "created", "src/app.css")
  assert string.contains(output, "gleam run -m drip -- add")
}

pub fn init_does_not_overwrite_existing_index_without_force_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init_exists")
  write_project(directory)
  write_source_theme(directory, "new\n")
  let assert Ok(Nil) = simplifile.create_directory_all(directory <> "/src/ui")
  let assert Ok(Nil) =
    simplifile.write(to: directory <> "/src/ui/index.css", contents: "old\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Error(error.ProjectFileAlreadyExists(_)) =
    cli.run(project, ["init"])

  // The gate fires before any write, so the pre-existing index is untouched.
  assert simplifile.read(directory <> "/src/ui/index.css") == Ok("old\n")
}

