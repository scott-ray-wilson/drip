pub fn init_records_prefix_and_source_in_one_edit_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init_prefix_source")
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/gleam.toml",
      contents: "name = \"app\"\n",
    )
  write_source_theme(directory, "/* tokens */\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(output) =
    cli.run(project, ["init", "--prefix=lib", "--source=" <> directory])

  // Both settings take effect; the theme lands under the new prefix,
  // fetched from the new source.
  assert simplifile.read(directory <> "/src/lib/theme.css")
    == Ok("/* tokens */\n")
  let assert Ok(gleam_toml) = simplifile.read(directory <> "/gleam.toml")
  assert string.contains(gleam_toml, "prefix = \"lib\"")
  assert string.contains(gleam_toml, "source = " <> toml_string(directory))
  let assert Ok(_) = project.load_from(directory)

  // The combined write touches gleam.toml exactly once.
  let modified_gleam_toml =
    output
    |> string.split("\n")
    |> list.filter(fn(line) {
      string.contains(line, "gleam.toml") && string.contains(line, "modified")
    })
  assert list.length(modified_gleam_toml) == 1
}

