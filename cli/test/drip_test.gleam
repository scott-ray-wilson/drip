pub fn init_source_flag_records_source_and_scaffolds_from_it_test() {
  use directory <- helpers.with_temp_directory("drip_e2e_init_source_flag")
  // A gleam.toml with no source, so the flag is the only thing providing one.
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/gleam.toml",
      contents: "name = \"app\"\n",
    )
  write_source_theme(directory, "/* tokens */\n")

  let assert Ok(project) = project.load_from(directory)
  let assert Ok(output) = cli.run(project, ["init", "--source=" <> directory])

  // The theme is fetched from the flag's source and scaffolded.
  assert simplifile.read(directory <> "/src/ui/theme.css")
    == Ok("/* tokens */\n")

  // The source is recorded in a fresh [tools.drip] table, so a reload resolves
  // it rather than falling back to the default release URL.
  let assert Ok(gleam_toml) = simplifile.read(directory <> "/gleam.toml")
  assert string.contains(gleam_toml, "source = " <> toml_string(directory))
  let assert Ok(_) = project.load_from(directory)

  // gleam.toml shows up as a modified file in the summary.
  assert_change(output, "modified", "gleam.toml")
}

