// --- Helpers -----------------------------------------------------------------

// Asserts some output line shows `label  <path>`.
fn assert_change(output: String, label: String, path: String) -> Nil {
  let matches = fn(line) {
    string.contains(line, label) && string.contains(line, path)
  }
  assert output |> string.split("\n") |> list.any(matches)
}

fn toml_string(value: String) -> String {
  let escaped =
    value
    |> string.replace("\\", "\\\\")
    |> string.replace("\"", "\\\"")
  "\"" <> escaped <> "\""
}

// A project whose registry source is the project directory itself.
fn write_project(directory: String) -> Nil {
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/gleam.toml",
      contents: "name = \"app\"\n\n[tools.drip]\nsource = "
        <> toml_string(directory)
        <> "\n",
    )

  Nil
}

fn write_registry(directory: String, elements: String) -> Nil {
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/registry.json",
      contents: "{\"schema_version\":1,\"elements\":[" <> elements <> "]}",
    )

  Nil
}

fn element(
  name: String,
  registry_dependencies: List(String),
  dependencies: List(String),
  files: List(String),
) -> String {
  "{\"name\":\""
  <> name
  <> "\",\"registry_dependencies\":["
  <> json_strings(registry_dependencies)
  <> "],\"dependencies\":["
  <> json_strings(dependencies)
  <> "],\"files\":["
  <> json_strings(files)
  <> "]}"
}

fn json_strings(items: List(String)) -> String {
  items |> list.map(fn(item) { "\"" <> item <> "\"" }) |> string.join(",")
}

fn write_project_with_prefix(directory: String, prefix: String) -> Nil {
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/gleam.toml",
      contents: "name = \"app\"\n\n[tools.drip]\nsource = "
        <> toml_string(directory)
        <> "\nprefix = "
        <> toml_string(prefix)
        <> "\n",
    )

  Nil
}

fn write_source_file(directory: String, name: String, contents: String) -> Nil {
  let assert Ok(Nil) = simplifile.write(to: directory <> "/" <> name, contents:)

  Nil
}

fn vendor(directory: String, name: String) -> Nil {
  let assert Ok(Nil) = simplifile.create_directory_all(directory <> "/src/ui")
  let assert Ok(Nil) =
    simplifile.write(
      to: directory <> "/src/ui/" <> name <> ".gleam",
      contents: "",
    )

  Nil
}

fn write_source_theme(directory: String, contents: String) -> Nil {
  let assert Ok(Nil) =
    simplifile.write(to: directory <> "/theme.css", contents:)

  Nil
}
